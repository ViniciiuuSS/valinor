    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "flowbite": "^4.0.1",
    "gsap": "^3.14.2",
    "ioredis": "^5.10.0",
    "kafkajs": "^2.2.4",
    "mqtt": "^5.15.0",
    "nats": "^2.29.3",
    "pg": "^8.19.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
